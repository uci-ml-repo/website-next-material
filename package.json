{
  "name": "mlrepo",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "format": "biome check --write --unsafe . && prettier --write .",
    "lint": "biome check . && prettier --check .",
    "prepare": "lefthook install",
    "typecheck": "pnpm -r --parallel typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@mlrepo/tsconfig": "workspace:*",
    "lefthook": "2.1.10",
    "prettier": "3.9.4",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-sql": "0.20.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=26"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11",
      "onFail": "download"
    }
  }
}
